<Window x:Class="EyeBreakEnforcer.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EyeBreakEnforcer Overlay"
        WindowStyle="None"
        Topmost="True"
        AllowsTransparency="True"
        Background="Black"
        KeyDown="Window_KeyDown">
    
    <Grid>
        <StackPanel x:Name="BreakControls" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
            
            <TextBlock x:Name="BreakMessage" 
                       Text="Time for a break!" 
                       FontSize="48" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,30"/>
            
            <TextBlock x:Name="CountdownText" 
                       Text="20" 
                       FontSize="72" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,50"/>
            
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center">
                
                <Button x:Name="SkipButton" 
                        Content="Skip Break" 
                        FontSize="18" 
                        Padding="20,10" 
                        Margin="10" 
                        Click="SkipButton_Click"/>
                
                <Button x:Name="SnoozeButton" 
                        Content="Snooze (5 min)" 
                        FontSize="18" 
                        Padding="20,10" 
                        Margin="10" 
                        Click="SnoozeButton_Click"/>
                
            </StackPanel>
            
        </StackPanel>
    </Grid>
</Window> 